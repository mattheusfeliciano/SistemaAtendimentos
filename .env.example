API_PORT=3001
FRONTEND_URL=http://localhost:3000
# Opcional: lista de origens separadas por virgula para CORS/CSRF (ex.: http://localhost:3000,http://localhost:5173)
# FRONTEND_URLS=http://localhost:5173
JWT_SECRET=troque-este-segredo-em-producao
APP_BASE_URL=http://localhost:3000
SESSION_HOURS=8
ENFORCE_HTTPS=false
TRUST_PROXY=false
TERMS_VERSION=2026-03-v1
PRIVACY_VERSION=2026-03-v1

# SMTP (opcional, recomendado para producao)
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_USER=usuario_smtp
# SMTP_PASS=senha_smtp
# SMTP_FROM="Dashboard Educacao <nao-responda@seudominio.com>"

# Frontend -> backend (opcional em dev com proxy do Vite)
# VITE_API_BASE_URL=http://localhost:3001

# Opcao 1: URL unica (recomendada em producao)
# DATABASE_URL=postgres://postgres:Postgres@2026!@localhost:5432/dash_educacao

# Opcao 2: variaveis separadas
PGHOST=localhost
PGPORT=5432
PGDATABASE=dash_educacao
PGUSER=postgres
PGPASSWORD=Postgres@2026!

# Use apenas se seu provedor exigir SSL
# PGSSLMODE=require

# Conta dedicada do painel do secretário
SECRETARY_FULL_NAME=SECRETÁRIO
SECRETARY_EMAIL=secretario@sect.local
SECRETARY_PASSWORD=Secretario@2026
SECRETARY_DEPARTMENT=Secretaria de Educação

# Conta ADMIN (superadmin com privilegios totais)
ROOT_ADMIN_FULL_NAME=ADMIN
ROOT_ADMIN_EMAIL=admin@sect.local
ROOT_ADMIN_PASSWORD=Admin@2026!
ROOT_ADMIN_DEPARTMENT=Tecnologia da Informacao

# Criptografia do chat (fallback por variavel)
# COMMENT_CRYPTO_KEYS=key-v1:minha-chave-antiga,key-v2:minha-chave-atual

# KMS logico para rotacao automatica e expurgo de chaves de chat
COMMENT_KMS_ENABLED=false
# COMMENT_KMS_MASTER_KEY=troque-por-um-segredo-longo-e-unico
COMMENT_CRYPTO_ROTATION_DAYS=30
COMMENT_CRYPTO_RETENTION_DAYS=120
COMMENT_CRYPTO_MAINTENANCE_MS=21600000
